{
  "name": "Gym Tracker",
  "icon": { "emoji": "🏋️" },
  "secrets": [],
  "tests": [
    { "name": "Home renders with demo data", "path": "/?demo=1", "expectText": "Staging demo" },
    { "name": "Home renders for real user", "path": "/", "expectText": "Start workout" },
    { "name": "Theme switcher renders", "path": "/", "expectSelector": "[data-action=\"set-theme\"]" },
    { "name": "Swipeable session rows render", "path": "/?demo=1", "expectSelector": "[data-swipe]" },
    { "name": "Desktop keeps X delete buttons", "path": "/?demo=1", "expectSelector": ".x-delete" },
    { "name": "Workout note snippet on home card", "path": "/?demo=1", "expectText": "Staging demo workout note" },
    { "name": "Import/export footer renders", "path": "/?demo=1", "expectText": "Export JSON" },
    { "name": "Import button renders", "path": "/", "expectSelector": "[data-action=\"import-json\"]" },
    { "name": "Import sheet opens with Copy format spec button", "path": "/?import=1", "expectSelector": "[data-action=\"copy-format-spec\"]" },
    { "name": "Unit toggle renders", "path": "/", "expectSelector": "[data-action=\"set-unit\"]" },
    { "name": "Session deep link opens the session view", "path": "/?demo=1&session=900002", "expectText": "Add exercise" },
    { "name": "Exercise X delete buttons render in session", "path": "/?demo=1&session=900002", "expectSelector": "[data-action=\"delete-entry\"]" },
    { "name": "Exercise picker opens with search box", "path": "/?demo=1&session=900002&picker=1", "expectSelector": "#picker-search" },
    { "name": "Exercise picker lists all demo exercises", "path": "/?demo=1&session=900002&picker=1", "expectText": "Staging demo plank" },
    { "name": "Picker shows exercise type badges", "path": "/?demo=1&session=900002&picker=1", "expectSelector": "[data-ex-type=\"time\"]" },
    { "name": "Progress entry point on home", "path": "/?demo=1", "expectSelector": "[data-action=\"open-progress\"]" },
    { "name": "Progress hub shows body diagram", "path": "/?demo=1&progress=1", "expectSelector": "[data-body-diagram]" },
    { "name": "Exercise chart deep link renders chart", "path": "/?demo=1&exercise=900001", "expectSelector": "[data-chart]" },
    { "name": "Exercise chart shows exercise name", "path": "/?demo=1&exercise=900001", "expectText": "Staging demo bench press" },
    { "name": "Time exercise chart renders", "path": "/?demo=1&exercise=900003", "expectSelector": "[data-chart]" },
    { "name": "Muscle chart deep link renders", "path": "/?demo=1&muscle=chest", "expectSelector": "[data-chart]" },
    { "name": "Muscle chart lists contributing exercise", "path": "/?demo=1&muscle=chest", "expectText": "Staging demo bench press" },
    { "name": "Muscle chart defaults to Est. 1RM with strength level", "path": "/?demo=1&muscle=chest", "expectText": "Intermediate" },
    { "name": "Quads strength score rolls up from the squat", "path": "/?demo=1&muscle=quads", "expectText": "Novice" },
    { "name": "Body map strength legend renders in demo", "path": "/?demo=1&progress=1", "expectText": "Advanced" },
    { "name": "Bodyweight prompt shows for a fresh user", "path": "/?progress=1", "expectText": "Set your bodyweight" },
    { "name": "Keyboard viewport directive present", "path": "/", "expectSelector": "meta[content*=\"interactive-widget\"]" }
  ]
}
